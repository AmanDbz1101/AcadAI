    "def validate_hierarchy(sections: List[Section], hierarchy: Dict) -> Dict:\n",
    "    \"\"\"\n",
    "    Validate the parsed hierarchy against the original text.\n",
    "    Check for:\n",
    "    - Proper nesting (no level skips)\n",
    "    - Malformed numbering\n",
    "    - Ambiguous entries\n",
    "    - Structural consistency\n",
    "    \"\"\"\n",
    "    issues = {\n",
    "        'level_skips': [],\n",
    "        'malformed_numbering': [],\n",
    "        'orphaned_sections': [],\n",
    "        'inconsistent_levels': [],\n",
    "        'warnings': [],\n",
    "        'summary': {}\n",
    "    }\n",
    "    \n",
    "    # Check for level skips (e.g., 1 -> 3 without 2)\n",
    "    prev_level = -1\n",
    "    for i, sec in enumerate(sections):\n",
    "        if sec.is_numbered and sec.level > prev_level + 1:\n",
    "            issues['level_skips'].append({\n",
    "                'index': i,\n",
    "                'section': sec.title,\n",
    "                'expected_level': prev_level + 1,\n",
    "                'actual_level': sec.level\n",
    "            })\n",
    "        prev_level = sec.level if sec.is_numbered else prev_level\n",
    "    \n",
    "    # Check numbering patterns\n",
    "    numbered_sections = [s for s in sections if s.is_numbered]\n",
    "    for sec in numbered_sections:\n",
    "        parts = sec.numbering.split('.')\n",
    "        for part in parts:\n",
    "            if not part.isdigit():\n",
    "                issues['malformed_numbering'].append({\n",
    "                    'section': sec.title,\n",
    "                    'numbering': sec.numbering\n",
    "                })\n",
    "    \n",
    "    # Check for orphaned sections (parents exist but not found)\n",
    "    sections_dict = hierarchy['sections']\n",
    "    for sec_id, sec in sections_dict.items():\n",
    "        if sec.parent_id is not None and sec.parent_id not in sections_dict:\n",
    "            issues['orphaned_sections'].append({\n",
    "                'section_id': sec_id,\n",
    "                'section': sec.title,\n",
    "                'parent_id': sec.parent_id\n",
    "            })\n",
    "    \n",
    "    # Count statistics\n",
    "    numbered_count = sum(1 for s in sections if s.is_numbered)\n",
    "    unnumbered_count = len(sections) - numbered_count\n",
    "    max_depth = max([s.level for s in sections]) if sections else 0\n",
    "    \n",
    "    issues['summary'] = {\n",
    "        'total_sections': len(sections),\n",
    "        'numbered_sections': numbered_count,\n",
    "        'unnumbered_sections': unnumbered_count,\n",
    "        'max_nesting_depth': max_depth,\n",
    "        'root_count': len(hierarchy['root_ids']),\n",
    "        'issues_found': len(issues['level_skips']) + len(issues['malformed_numbering']) + len(issues['orphaned_sections'])\n",
    "    }\n",
    "    \n",
    "    return issues\n",
    "\n",
    "# Validate the hierarchy\n",
    "validation_results = validate_hierarchy(sections, hierarchy)\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"VALIDATION REPORT\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"\\nSummary:\")\n",
    "for key, value in validation_results['summary'].items():\n",
    "    print(f\"  {key}: {value}\")\n",
    "\n",
    "if validation_results['level_skips']:\n",
    "    print(f\"\\n⚠️  Level Skips Detected ({len(validation_results['level_skips'])}):\")\n",
    "    for skip in validation_results['level_skips']:\n",
    "        print(f\"  - '{skip['section']}' (Level {skip['actual_level']}, expected {skip['expected_level']})\")\n",
    "\n",
    "if validation_results['malformed_numbering']:\n",
    "    print(f\"\\n❌ Malformed Numbering ({len(validation_results['malformed_numbering'])}):\")\n",
    "    for bad in validation_results['malformed_numbering']:\n",
    "        print(f\"  - '{bad['section']}' (numbering: {bad['numbering']})\")\n",
    "\n",
    "if validation_results['orphaned_sections']:\n",
    "    print(f\"\\n❌ Orphaned Sections ({len(validation_results['orphaned_sections'])}):\")\n",
    "    for orphan in validation_results['orphaned_sections']:\n",
    "        print(f\"  - '{orphan['section']}' (ID: {orphan['section_id']}, parent ID: {orphan['parent_id']})\")\n",
    "\n",
    "if validation_results['summary']['issues_found'] == 0:\n",
    "    print(\"\\n✅ Validation passed! No structural issues detected.\")\n",
    "else:\n",
    "    print(f\"\\n⚠️  Total issues found: {validation_results['summary']['issues_found']}\")\n",
    "\n",
    "print(\"=\" * 70)"
   ]
  },
