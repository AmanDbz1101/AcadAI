    "def query_hierarchy(hierarchy: Dict, query_type: str, query_param: str = None):\n",
    "    \"\"\"\n",
    "    Query the temporary in-memory hierarchy for various purposes.\n",
    "    Supports: find_section, get_all_descendants, get_path_to_root, find_siblings\n",
    "    \"\"\"\n",
    "    sections = hierarchy['sections']\n",
    "    results = []\n",
    "    \n",
    "    if query_type == 'find_section':\n",
    "        # Find section by partial title match\n",
    "        for sec_id, sec in sections.items():\n",
    "            if query_param.lower() in sec.title.lower():\n",
    "                results.append({\n",
    "                    'id': sec_id,\n",
    "                    'title': sec.title,\n",
    "                    'numbering': sec.numbering if sec.is_numbered else 'N/A',\n",
    "                    'level': sec.level\n",
    "                })\n",
    "    \n",
    "    elif query_type == 'get_all_descendants':\n",
    "        # Get all descendants of a section\n",
    "        sec_id = int(query_param)\n",
    "        if sec_id in sections:\n",
    "            visited = set()\n",
    "            def collect_descendants(sid):\n",
    "                if sid in visited:\n",
    "                    return\n",
    "                visited.add(sid)\n",
    "                sec = sections[sid]\n",
    "                for child_id in sec.children_ids:\n",
    "                    child_sec = sections[child_id]\n",
    "                    results.append({\n",
    "                        'id': child_id,\n",
    "                        'title': child_sec.title,\n",
    "                        'numbering': child_sec.numbering if child_sec.is_numbered else 'N/A',\n",
    "                        'level': child_sec.level,\n",
    "                        'relation': 'descendant'\n",
    "                    })\n",
    "                    collect_descendants(child_id)\n",
    "            collect_descendants(sec_id)\n",
    "    \n",
    "    elif query_type == 'get_path_to_root':\n",
    "        # Get path from section to root\n",
    "        sec_id = int(query_param)\n",
    "        current_id = sec_id\n",
    "        while current_id is not None:\n",
    "            sec = sections[current_id]\n",
    "            results.append({\n",
    "                'id': current_id,\n",
    "                'title': sec.title,\n",
    "                'numbering': sec.numbering if sec.is_numbered else 'N/A',\n",
    "                'level': sec.level\n",
    "            })\n",
    "            current_id = sec.parent_id\n",
    "        results.reverse()\n",
    "    \n",
    "    return results\n",
    "\n",
    "print(\"\\n\" + \"=\" * 70)\n",
    "print(\"HIERARCHY QUERY EXAMPLES\")\n",
    "print(\"=\" * 70)\n",
    "\n",
    "# Example 1: Find all sections with \"MemGPT\" in the title\n",
    "print(\"\\n[Query 1] Find sections matching 'MemGPT':\")\n",
    "memgpt_sections = query_hierarchy(hierarchy, 'find_section', 'MemGPT')\n",
    "for result in memgpt_sections:\n",
    "    print(f\"  - ID {result['id']}: {result['numbering']} {result['title']}\")\n",
    "\n",
    "# Example 2: Get all descendants of section with numbering \"3\"\n",
    "print(\"\\n[Query 2] All descendants of section '3. Experiments':\")\n",
    "experiments_id = next((i for i, s in hierarchy['sections'].items() if s.title == 'Experiments'), None)\n",
    "if experiments_id is not None:\n",
    "    descendants = query_hierarchy(hierarchy, 'get_all_descendants', str(experiments_id))\n",
    "    for result in descendants:\n",
    "        print(f\"  - ID {result['id']}: {result['numbering']} {result['title']}\")\n",
    "\n",
    "# Example 3: Get path from a deep section back to root\n",
    "print(\"\\n[Query 3] Path from section '3.1.1. DEEP MEMORY RETRIEVAL TASK' to root:\")\n",
    "deep_section_id = next((i for i, s in hierarchy['sections'].items() \n",
    "                         if 'DEEP MEMORY RETRIEVAL' in s.title), None)\n",
    "if deep_section_id is not None:\n",
    "    path = query_hierarchy(hierarchy, 'get_path_to_root', str(deep_section_id))\n",
    "    for i, result in enumerate(path):\n",
    "        indent = \"  \" * i\n",
    "        print(f\"{indent}└─ ID {result['id']}: {result['numbering']} {result['title']}\")\n",
    "\n",
    "print(\"\\n\" + \"=\" * 70)"
   ]
