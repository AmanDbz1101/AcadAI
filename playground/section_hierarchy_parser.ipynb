    "def generate_parent_child_notation(hierarchy: Dict) -> List[Dict]:\n",
    "    \"\"\"\n",
    "    Generate a normalized representation for each node showing:\n",
    "    - Section name\n",
    "    - Its parent (with numbering/name)\n",
    "    - Its immediate children (with numbering/name)\n",
    "    \n",
    "    Uses only temporary notebook variables (no database).\n",
    "    \"\"\"\n",
    "    notation_list = []\n",
    "    sections = hierarchy['sections']\n",
    "    \n",
    "    for sec_id, section in sections.items():\n",
    "        parent_info = None\n",
    "        if section.parent_id is not None:\n",
    "            parent_sec = sections[section.parent_id]\n",
    "            parent_info = {\n",
    "                'id': section.parent_id,\n",
    "                'name': parent_sec.title,\n",
    "                'numbering': parent_sec.numbering if parent_sec.is_numbered else 'N/A',\n",
    "                'level': parent_sec.level\n",
    "            }\n",
    "        \n",
    "        children_info = []\n",
    "        for child_id in section.children_ids:\n",
    "            child_sec = sections[child_id]\n",
    "            children_info.append({\n",
    "                'id': child_id,\n",
    "                'name': child_sec.title,\n",
    "                'numbering': child_sec.numbering if child_sec.is_numbered else 'N/A',\n",
    "                'level': child_sec.level\n",
    "            })\n",
    "        \n",
    "        notation_entry = {\n",
    "            'id': sec_id,\n",
    "            'title': section.title,\n",
    "            'level': section.level,\n",
    "            'numbering': section.numbering if section.is_numbered else 'N/A',\n",
    "            'is_numbered': section.is_numbered,\n",
    "            'parent': parent_info,\n",
    "            'children': children_info\n",
    "        }\n",
    "        \n",
    "        notation_list.append(notation_entry)\n",
    "    \n",
    "    return notation_list\n",
    "\n",
    "# Generate parent/child notation\n",
    "notation_data = generate_parent_child_notation(hierarchy)\n",
