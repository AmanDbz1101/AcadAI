    "@dataclass\n",
    "class Section:\n",
    "    \"\"\"Represents a section with its hierarchical metadata.\"\"\"\n",
    "    title: str\n",
    "    level: int  # 0 = title, 1 = numbered 1, 2 = numbered 1.1, 3 = numbered 1.1.1, etc.\n",
    "    numbering: str  # e.g., \"2.1.3\"\n",
    "    is_numbered: bool  # True if has numeric prefix\n",
    "    parent_id: Optional[int] = None\n",
    "    children_ids: List[int] = None\n",
    "    \n",
    "    def __post_init__(self):\n",
    "        if self.children_ids is None:\n",
    "            self.children_ids = []\n",
    "    \n",
    "    def __repr__(self):\n",
    "        indent = \"  \" * (self.level - 1) if self.level > 0 else \"\"\n",
    "        if self.is_numbered:\n",
    "            return f\"{indent}[Lvl {self.level}] {self.numbering}. {self.title}\"\n",
    "        else:\n",
    "            return f\"{indent}[Lvl {self.level}] {self.title}\"\n",
    "\n",
    "def parse_section_lines(raw_text: str) -> List[Section]:\n",
    "    \"\"\"\n",
    "    Parse raw hierarchy text and extract section information.\n",
    "    Detect heading levels from numbering patterns (1., 2., 2.1., 2.1.1., etc.)\n",
    "    and preserve unnumbered top-level entries.\n",
    "    \"\"\"\n",
    "    lines = raw_text.strip().split('\\n')\n",
    "    sections = []\n",
    "    \n",
    "    for line in lines:\n",
    "        # Remove leading dash and whitespace\n",
    "        line_content = line.strip()\n",
    "        if line_content.startswith('- '):\n",
    "            line_content = line_content[2:].strip()\n",
    "        \n",
    "        if not line_content:\n",
    "            continue\n",
    "        \n",
    "        # Regex to detect numbered sections: 1, 2.3, 3.1.2, etc.\n",
    "        number_pattern = r'^(\\d+(?:\\.\\d+)*)\\.\\s+(.*)$'\n",
    "        match = re.match(number_pattern, line_content)\n",
    "        \n",
    "        if match:\n",
    "            numbering = match.group(1)\n",
    "            title = match.group(2).strip()\n",
    "            # Calculate level: 1 for \"1\", 2 for \"1.1\", 3 for \"1.1.1\", etc.\n",
    "            level = len(numbering.split('.'))\n",
    "            section = Section(\n",
    "                title=title,\n",
    "                level=level,\n",
    "                numbering=numbering,\n",
    "                is_numbered=True\n",
    "            )\n",
    "        else:\n",
    "            # Unnumbered entry (special cases like \"Abstract\", \"References\", etc.)\n",
    "            title = line_content\n",
    "            section = Section(\n",
    "                title=title,\n",
    "                level=0,  # Treat as top-level\n",
    "                numbering=\"\",\n",
    "                is_numbered=False\n",
    "            )\n",
    "        \n",
    "        sections.append(section)\n",
    "    \n",
    "    return sections\n",
    "\n",
    "# Parse sections\n",
    "sections = parse_section_lines(raw_hierarchy_text)\n",
    "\n",
    "print(f\"Parsed {len(sections)} sections\\n\")\n",
    "print(\"Sample of parsed sections:\")\n",
    "for i, sec in enumerate(sections[:15]):\n",
    "    print(f\"  {i}: {sec}\")"
   ]
