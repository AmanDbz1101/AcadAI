    "def render_hierarchy_tree(hierarchy: Dict, max_depth: Optional[int] = None) -> str:\n",
    "    \"\"\"\n",
    "    Render the hierarchy as an indented tree with visual markers.\n",
    "    Uses temporary notebook variables to build the output string.\n",
    "    \"\"\"\n",
    "    sections = hierarchy['sections']\n",
    "    root_ids = hierarchy['root_ids']\n",
    "    output_lines = []\n",
    "    visited = set()\n",
    "    \n",
    "    def traverse(sec_id: int, depth: int = 0, is_last: bool = True, prefix: str = \"\"):\n",
    "        if sec_id in visited:\n",
    "            return\n",
    "        visited.add(sec_id)\n",
    "        \n",
    "        if max_depth and depth > max_depth:\n",
    "            return\n",
    "        \n",
    "        section = sections[sec_id]\n",
    "        \n",
    "        # Build tree markers\n",
    "        if depth == 0:\n",
    "            marker = \"\"\n",
    "            current_prefix = \"\"\n",
    "        else:\n",
    "            connector = \"└── \" if is_last else \"├── \"\n",
    "            marker = connector\n",
    "            if prefix:\n",
    "                current_prefix = prefix + marker\n",
    "            else:\n",
    "                current_prefix = marker\n",
    "        \n",
    "        # Format section line\n",
    "        if section.is_numbered:\n",
    "            line = f\"{current_prefix}{section.numbering}. {section.title}\"\n",
    "        else:\n",
    "            line = f\"{current_prefix}{section.title}\"\n",
    "        \n",
    "        output_lines.append(line)\n",
    "        \n",
    "        # Traverse children\n",
    "        for i, child_id in enumerate(section.children_ids):\n",
    "            is_last_child = (i == len(section.children_ids) - 1)\n",
    "            if depth == 0:\n",
    "                next_prefix = \"\"\n",
    "            else:\n",
    "                next_prefix = prefix + (\"    \" if is_last else \"│   \")\n",
    "            traverse(child_id, depth + 1, is_last_child, next_prefix)\n",
    "    \n",
    "    # Start traversal from root sections\n",
    "    for i, root_id in enumerate(root_ids):\n",
    "        traverse(root_id, depth=0)\n",
    "    \n",
    "    return \"\\n\".join(output_lines)\n",
    "\n",
    "# Render the full hierarchy tree\n",
    "tree_output = render_hierarchy_tree(hierarchy)\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"SECTION HIERARCHY TREE (WITH INDENTATION AND MARKERS)\")\n",
    "print(\"=\" * 70)\n",
    "print(tree_output)\n",
    "print(\"=\" * 70)"
   ]
