    "def build_hierarchy_tree(sections: List[Section]) -> Dict:\n",
    "    \"\"\"\n",
    "    Build an in-memory temporary tree structure that assigns each section its parent\n",
    "    based on the detected level and maintains children lists.\n",
    "    \n",
    "    Returns:\n",
    "        Dict with 'sections' (indexed by id) and 'root_ids' (top-level section ids)\n",
    "    \"\"\"\n",
    "    section_stack = []  # Stack of (level, section_index)\n",
    "    \n",
    "    for i, section in enumerate(sections):\n",
    "        # Assign section ID\n",
    "        section.id = i\n",
    "        \n",
    "        if section.level == 0:\n",
    "            # Top-level unnumbered section\n",
    "            section.parent_id = None\n",
    "            section_stack = []\n",
    "        else:\n",
    "            # Pop stack until we find a parent at level (current_level - 1)\n",
    "            while section_stack and section_stack[-1][0] >= section.level:\n",
    "                section_stack.pop()\n",
    "            \n",
    "            if section_stack:\n",
    "                parent_idx = section_stack[-1][1]\n",
    "                section.parent_id = parent_idx\n",
    "                sections[parent_idx].children_ids.append(i)\n",
    "            else:\n",
    "                section.parent_id = None\n",
    "        \n",
    "        # Push current section onto stack\n",
    "        section_stack.append((section.level, i))\n",
    "    \n",
    "    # Build lookup dictionary\n",
    "    hierarchy_dict = {\n",
    "        'sections': {i: sec for i, sec in enumerate(sections)},\n",
    "        'root_ids': [i for i, sec in enumerate(sections) if sec.parent_id is None]\n",
    "    }\n",
    "    \n",
    "    return hierarchy_dict\n",
    "\n",
    "# Build the temporary tree in memory\n",
    "hierarchy = build_hierarchy_tree(sections)\n",
    "\n",
    "print(f\"Hierarchy built successfully!\")\n",
    "print(f\"Root sections (top-level): {len(hierarchy['root_ids'])}\")\n",
    "print(f\"Total sections indexed: {len(hierarchy['sections'])}\\n\")\n",
    "\n",
    "# Display some examples\n",
    "print(\"Example parent-child relationships:\")\n",
    "for sec_id in list(hierarchy['root_ids'])[:3]:\n",
    "    sec = hierarchy['sections'][sec_id]\n",
    "    if sec.children_ids:\n",
    "        print(f\"\\nParent: {sec.title} (ID: {sec_id})\")\n",
    "        for child_id in sec.children_ids[:3]:\n",
    "            child = hierarchy['sections'][child_id]\n",
    "            print(f\"  ↳ Child: {child.title} (ID: {child_id})\")"
   ]
