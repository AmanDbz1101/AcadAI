    "import pandas as pd\n",
    "\n",
    "# Create a dataframe for easy visualization\n",
    "df_data = []\n",
    "for entry in notation_data:\n",
    "    parent_str = f\"[{entry['parent']['numbering']}] {entry['parent']['name']}\" if entry['parent'] else \"ROOT\"\n",
    "    children_count = len(entry['children'])\n",
    "    children_preview = \", \".join([f\"[{c['numbering']}] {c['name'][:25]}{'...' if len(c['name']) > 25 else ''}\" \n",
    "                                   for c in entry['children'][:2]])\n",
    "    if len(entry['children']) > 2:\n",
    "        children_preview += f\", +{len(entry['children']) - 2} more\"\n",
    "    \n",
    "    df_data.append({\n",
    "        'ID': entry['id'],\n",
    "        'Level': entry['level'],\n",
    "        'Numbering': entry['numbering'],\n",
    "        'Section Title': entry['title'],\n",
    "        'Parent': parent_str,\n",
    "        'Child Count': children_count,\n",
    "        'Children Preview': children_preview if children_preview else \"(leaf)\"\n",
    "    })\n",
    "\n",
    "df = pd.DataFrame(df_data)\n",
    "\n",
    "print(\"\\n\" + \"=\" * 150)\n",
    "print(\"SECTION HIERARCHY TABLE (Parent-Child Relationships)\")\n",
    "print(\"=\" * 150)\n",
    "print(df.to_string(index=False))\n",
    "print(\"=\" * 150)\n",
    "\n",
    "# Export statistics\n",
    "print(f\"\\n📊 Statistics:\")\n",
    "print(f\"  • Total sections: {len(df)}\")\n",
    "print(f\"  • Sections with children: {(df['Child Count'] > 0).sum()}\")\n",
    "print(f\"  • Leaf sections (no children): {(df['Child Count'] == 0).sum()}\")\n",
    "print(f\"  • Maximum nesting depth: {df['Level'].max()}\")\n",
    "print(f\"  • Root sections: {(df['Parent'] == 'ROOT').sum()}\")"
   ]
