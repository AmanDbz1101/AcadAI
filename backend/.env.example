# Environment Configuration for Research Paper Assistant Backend
# Copy this file to .env and configure as needed

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false

# ============================================================================
# File Upload Configuration
# ============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
EXTRACTION_TIMEOUT=120

# ============================================================================
# OCR Configuration
# ============================================================================
ENABLE_OCR=true
OCR_MIN_TEXT_DENSITY=50.0

# ============================================================================
# CORS Configuration
# ============================================================================
# Use "*" for development, specific origins for production
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_DIR=logs

# ============================================================================
# LLM Configuration (for metadata extraction)
# ============================================================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
ENABLE_LLM_FALLBACK=true
LLM_FALLBACK_THRESHOLD=0.6

# ============================================================================
# Vector Store Configuration (for downstream modules)
# ============================================================================
# QDRANT_URL=your_qdrant_url_here
# QDRANT_API_KEY=your_qdrant_api_key_here
# QDRANT_COLLECTION_NAME=research_papers

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_CLEANUP_ENDPOINT=true
ENABLE_DETAILED_ERRORS=true
ENABLE_CACHE=false

# ============================================================================
# Cache Configuration
# ============================================================================
CACHE_DIR=cache

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_PER_MINUTE=10
